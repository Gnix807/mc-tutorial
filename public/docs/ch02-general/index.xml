bilityData ? durabilityData.split(&#34;,&#34;).map(d =&gt; parseFloat(d.trim())) : [];&#xA;    let currentIndex = 0;&#xA;    const img = slot.querySelector(&#34;img&#34;);&#xA;    const durContainer = slot.querySelector(&#34;.mc-durability-container&#34;);&#xA;    const durFill = slot.querySelector(&#34;.mc-durability-fill&#34;);&#xA;&#xA;    &#xA;    img.onload = function() {&#xA;      &#xA;      if (this.naturalWidth &lt;= 32) {&#xA;        this.style.imageRendering = &#34;pixelated&#34;;&#xA;      } else {&#xA;        this.style.imageRendering = &#34;auto&#34;;&#xA;      }&#xA;    };&#xA;&#xA;    &#xA;    function updateSlot() {&#xA;      const itemKey = items[currentIndex];&#xA;      if (itemKey === &#34;empty&#34; || !itemKey) {&#xA;        img.style.opacity = 0;&#xA;        img.src = &#34;&#34;;&#xA;        slot.setAttribute(&#34;data-active-item&#34;, &#34;&#34;);&#xA;        if (durContainer) durContainer.style.display = &#34;none&#34;;&#xA;      } else {&#xA;        img.src = &#34;/images/items/&#34; + itemKey + &#34;.png&#34;;&#xA;        img.style.opacity = 1;&#xA;        slot.setAttribute(&#34;data-active-item&#34;, itemKey);&#xA;        &#xA;        &#xA;        if (durContainer &amp;&amp; durVals[currentIndex] !== undefined &amp;&amp; !isNaN(durVals[currentIndex])) {&#xA;          const val = durVals[currentIndex];&#xA;          durContainer.style.display = &#34;block&#34;;&#xA;          durFill.style.width = (val * 100) + &#34;%&#34;;&#xA;          &#xA;          const hue = Math.max(0, val * 120);&#xA;          durFill.style.backgroundColor = `hsl(${hue}, 100%, 50%)`;&#xA;        } else if (durContainer) {&#xA;          durContainer.style.display = &#34;none&#34;;&#xA;        }&#xA;      }&#xA;    }&#xA;    updateSlot();&#xA;&#xA;    &#xA;    if (items.length &gt; 1) {&#xA;      setInterval(() =&gt; {&#xA;        img.style.opacity = 0;&#xA;        setTimeout(() =&gt; {&#xA;          currentIndex = (currentIndex + 1) % items.length;&#xA;          updateSlot();&#xA;        }, 150);&#xA;      }, 2000);&#xA;    }&#xA;&#xA;    &#xA;    slot.addEventListener(&#34;mouseenter&#34;, (e) =&gt; {&#xA;      const activeItem = slot.getAttribute(&#34;data-active-item&#34;);&#xA;      if (!activeItem) return;&#xA;&#xA;      const translation = mcTooltips[activeItem] || { title: activeItem, subtitle: &#34;物品&#34; };&#xA;      tooltip.querySelector(&#34;.mc-tooltip-title&#34;).textContent = translation.title;&#xA;      tooltip.querySelector(&#34;.mc-tooltip-subtitle&#34;).textContent = translation.subtitle;&#xA;      tooltip.style.display = &#34;block&#34;;&#xA;    });&#xA;&#xA;    slot.addEventListener(&#34;mousemove&#34;, (e) =&gt; {&#xA;      &#xA;      tooltip.style.left = (e.clientX + 12) + &#34;px&#34;;&#xA;      tooltip.style.top = (e.clientY - 12) + &#34;px&#34;;&#xA;    });&#xA;&#xA;    slot.addEventListener(&#34;mouseleave&#34;, () =&gt; {&#xA;      tooltip.style.display = &#34;none&#34;;&#xA;    });&#xA;  });&#xA;})();&#xA;&lt;/script&gt;&#xA;&lt;/p&gt;</description>
